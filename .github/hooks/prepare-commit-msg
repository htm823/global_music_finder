#!/bin/bash

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Define valid types
TYPES="feat|fix|docs|refactor|chore"

if [ "$COMMIT_SOURCE" = "merge" ]; then
    LAST_MSG=$(git log -1 --pretty=%B)
    NEW_MSG=$(echo "$LAST_MSG" | sed -E "s/^($TYPES):/merge:/")
    echo "$NEW_MSG" > "$COMMIT_MSG_FILE"
    exit 0
fi

BRANCH_NAME=$(git symbolic-ref --short HEAD 2>/dev/null)
if [[ $BRANCH_NAME =~ ^($TYPES)/ ]]; then
    TYPE="${BASH_REMATCH[1]}"
    CURRENT_MSG=$(cat "$COMMIT_MSG_FILE")

    if [[ ! $CURRENT_MSG =~ ^($TYPES): ]]; then
        echo "${TYPE}: ${CURRENT_MSG}" > "$COMMIT_MSG_FILE"
    else
        echo "$CURRENT_MSG" | sed -E "s/^($TYPES):/${TYPE}:/" > "$COMMIT_MSG_FILE"
    fi
fi

exit 0