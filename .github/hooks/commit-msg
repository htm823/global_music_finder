#!/bin/bash

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Define valid types
TYPES="feat|fix|docs|refactor|chore"

# Check if commit message follows the format
if [[ ! $COMMIT_MSG =~ ^($TYPES):.+ ]]; then
    echo "❌ Error: Commit message must start with a valid type: ($TYPES)"
    exit 1
fi

# Check message length (subject line should be under 72 characters)
SUBJECT_LINE=$(echo "$COMMIT_MSG" | head -n1)
if [ ${#SUBJECT_LINE} -gt 72 ]; then
    echo "⚠️  Warning: Subject line is too long (> 72 chars)"
fi

exit 0